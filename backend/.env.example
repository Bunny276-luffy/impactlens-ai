# Database URL for Amazon Aurora PostgreSQL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/impactlens?schema=public"

# Next Auth Secret (Generate using: openssl rand -base64 32)
NEXTAUTH_SECRET="your_nextauth_secret_key_here"
NEXTAUTH_URL="http://localhost:4000"
